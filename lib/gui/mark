cleanurl() {
  local url="$1"

  # read -r url < <(sed -E 's/[#?].*//g' <<<"$url")
  read -r url < <(sed -E 's/\/$//' <<<"$url")

  echo "$url"
}

json() {
  local mode="$1"
  local ikey key val opts args json

  shift 1

  while (( $# > 0 )); do
    key="$1"
    val="$2"

    shift 2

    [[ "$key" == newurl && -z "$val" ]] && continue

    [[ "$key" == newurl ]] && ikey=url || ikey="$key"

    [[ "$key" == s && -z "$val" ]] && val=0

    opts+=(--arg "$key" "$val")

    case "$mode" in
      new)
        if [[ "$key" == s ]]; then
          args+=("$key:(\$$key | tonumber)")
        else
          args+=("$key:\$$key")
        fi
        ;;
      mod)
        if [[ "$key" != url ]]; then
          if [[ "$key" == s ]]; then
            args+=("\
              .$ikey |= ( \
                if . == null or . == \"\" then 0 \
                elif \$s == \"2\" then (1 - .) \
                elif \$s == \"1\" or \$s == \"0\" then (\$s | tonumber) \
                else . end \
              ) \
            ")
          else
            args+=(".$ikey |= (if \$$key == \"\" then . else \$$key end)")
          fi
        fi
    esac
  done

  case "$mode" in
    new)
      read -r json < <(IFS=,; printf "inputs, {%s}\n" "${args[*]}")
      jq -n -c "${opts[@]}" "$json"
      ;;
    mod)
      read -r json < \
        <(IFS='|'; printf 'if .url == $url then %s else . end\n' "${args[*]}")
      jq -c "${opts[@]}" "$json"
  esac
}

insert() {
  local url="$1"
  local title="$2"

  local entries key val
  local -A values

  values[url]="$url"

  if [[ -z "$url" ]]; then
    values[url]=`tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 15`
  fi

  readarray -t entries < <(readeval <<< "$title")

  for entry in "${entries[@]}"; do
    IFS=: read -r key val <<< "$entry"
    values[$key]="$val"
  done

  if ! check "$url"; then
    mode=new
  else
    mode=mod
  fi

  local txt

  read -r -d '' txt < "$JS"

  <<< "$txt" > "$JS" json "$mode" \
  url "${values[url]}" \
  newurl "${values[newurl]}" \
  type "${values[type]}" \
  kind "${values[kind]}" \
  tag "${values[tag]}" \
  desc "${values[desc]}" \
  s "${values[s]}"

  # jq -s -c 'sort_by(.type, .kind, .tag, .desc)[]' "$tmp" > "$JS"
}

