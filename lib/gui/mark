edit() {
  local mode="$1" url="$2" title="$3" entries key val
  local -A keyvals

  readarray -t entries < <(readeval <<< "$title")

  for entry in "${entries[@]}"; do
    IFS=: read -r key val <<< "$entry"
    [[ -n "$key" ]] && keyvals[$key]="$val"
  done

  (
    echo "newurl: ${keyvals[newurl]}"
    echo "type: ${keyvals[type]}"
    echo "kind: ${keyvals[kind]}"
    echo "tag: ${keyvals[tag]}"
    echo "desc: ${keyvals[desc]}"
  ) | tmux load-buffer -b preview -

  case "$mode" in
    menu)
      menu input label="' [$url] '"
      ;;
    *)
      input label="' [$url] '"
      ;;
  esac
}


BINDS[cleanurl]='alt-r'
HOOKS[cleanurl]='sclear'
DESCS[cleanurl]='cleanurl'
cleanurl() {
  local url newurl

  read -r url _ <<<"$1"

  newurl="${url%%[\?#]*}"

  insert "$url" "newurl:'${newurl}'"
}

BINDS[star]='alt-t'
HOOKS[star]='sclear'
DESCS[star]='star'
star() {
  local url newurl

  read -r url _ <<< "$1"

  insert "$url" 's:"2"'
}

add() {
  local url="$1" data="$2"

  if check "$url"; then
    notify "'$url' already exists"
    return 1
  fi

  read -r data < <(edit menu "$url" "$data")

  [[ -z "$data" ]] && return

  check "$url" || insert "$url" "$data"

  if check "$url"; then
    notify "Added '$url'"
  else
    notify "Failed to add '$url'"
  fi
}

del() {
  local url="$1"

  if check "$url"; then
    sqlite3 "$DB" "DELETE FROM bookmarks WHERE url == '$url'"
    if check "$url"; then
      notify "Failed to delete '$url'"
    else
      notify "Deleted '$url'"
    fi
  else
    notify "'$url' does not exist"
  fi
}
