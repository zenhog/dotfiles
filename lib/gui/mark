list() {
  # printf '.%s | $%s + . + $%s' ""

  jq -r \
    --arg sep "$iSEP" \
    --arg c_reset "$(colorize code reset)" \
    --arg c_type "$(colorize code green)" \
    --arg c_kind "$(colorize code magenta)" \
    --arg c_tag "$(colorize code yellow)" \
    --arg c_desc "$(colorize code cyan)" \
  '.url + $sep +
  (if .s == 1 then "*" else "-" end) + $sep +
  (.type | $c_type + . + $c_reset) + $sep +
  (.kind | $c_kind + . + $c_reset) + $sep +
  (.tag | $c_tag + . + $c_reset) + $sep +
  (.desc | $c_desc + . + $c_reset)' "$JS" |
    column -t -s "$iSEP" -N URL,STAR,TYPE,KIND,TAG,DESC
}

