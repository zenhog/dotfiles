check() {
  local url="$1"

  # read -r url < <(cleanurl "$url")

  mute jq -e --arg url "$url" '(select(.url == $url))' "$JS"
}

BINDS[rm]=alt-d
HOOKS[rm]=noclear
DESCS[rm]='Delete'
rm() {
  local url tmp

  read -r tmp < <(mktemp)

  read -r url _ <<< "$1"

  if check "$url"; then
    grep -vF "\"url\":\"$url\"" "$JS" > "$tmp"
    mv "$tmp" "$JS"
  fi
}

BINDS[mod]=alt-w
HOOKS[mod]=sclear
DESCS[mod]='Rename'
mod() {
  local url data star type kind tag desc

  read -r url star type kind tag desc <<< "$1"

  read -r data < <(
    printf 'newurl:"%s" star:"%s" type:"%s" kind:"%s" tag:"%s" desc:"%s"\n' \
      "$url" "$star" "$type" "$kind" "$tag" "$desc"
  )

  read -r data < <(edit nomenu "$url" "$data")

  if [[ -n "$data" ]]; then
    insert "$url" "$data"
  fi
}

