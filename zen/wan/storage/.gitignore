*
!.gitignore
!/default/
!/default/chrome/
!/default/chrome/**
!/default/moz-extension*/
!/default/moz-extension*/.metadata*
!/default/moz-extension*/idb/
!/default/moz-extension*/idb/*.sqlite
!/default/moz-extension*/idb/*.sqlite-shm
!/default/moz-extension*/idb/*.sqlite-wal
!/permanent/
!/permanent/chrome/
!/permanent/chrome/.metadata*
!/permanent/chrome/idb/
!/permanent/chrome/idb/*.sqlite
!/permanent/chrome/idb/*.sqlite-shm
!/permanent/chrome/idb/*.sqlite-wal
!/permanent/indexeddb*/
!/permanent/indexeddb*/.metadata*
!/permanent/indexeddb*/idb/
!/permanent/indexeddb*/idb/*.sqlite
!/permanent/indexeddb*/idb/*.sqlite-shm
!/permanent/indexeddb*/idb/*.sqlite-wal
